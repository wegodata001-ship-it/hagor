generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  CUSTOMER
}

enum DeliveryType {
  PICKUP
  SHIPPING
}

enum CouponType {
  PERCENT
  FIXED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

/// Customer-facing fulfillment / tracking stage (independent of payment).
enum OrderFulfillmentStatus {
  RECEIVED
  PROCESSING
  PACKED
  SHIPPED
  COMPLETED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum LoyaltyRewardType {
  DISCOUNT
  FREE_SHIPPING
  FREE_PRODUCT
  COUPON
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum PaymentWebhookLogStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  ERROR
  IGNORED
}

enum BannerType {
  HERO
  SECTION
  POPUP
  PROMO
}

model Store {
  id          String      @id
  name        String
  slug        String      @unique
  domain      String?
  templateKey String      @default("default")
  status      StoreStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  settings          StoreSettings?
  users             User[]
  customerProfiles  CustomerProfile[]
  categories        Category[]
  products          Product[]
  membershipPlans   MembershipPlan[]
  productImages     ProductImage[]
  banners           Banner[]
  deliveryOptions   DeliveryOption[]
  coupons           Coupon[]
  orders            Order[]
  orderItems        OrderItem[]
  payments          Payment[]
  loyaltySettings   LoyaltySettings?
  loyaltyRewards    LoyaltyReward[]
  loyaltyTransactions LoyaltyTransaction[]
  adminActionLogs     AdminActionLog[]
  paymentWebhookLogs  PaymentWebhookLog[]
  emailVerificationTokens EmailVerificationToken[]
  observabilityEvents ObservabilityEvent[]
}

/// Production telemetry (errors, slow queries, auth timings, Prisma metrics). Retention enforced in app layer.
model ObservabilityEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  traceId    String?
  level      String
  scope      String
  message    String
  queryKey   String?
  path       String?
  durationMs Int?
  errorText  String? @db.Text
  meta       Json?

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, level, createdAt(sort: Desc)])
  @@index([storeId, message, createdAt(sort: Desc)])
  @@index([storeId, path, createdAt(sort: Desc)])
  @@index([storeId, queryKey, createdAt(sort: Desc)])
  @@index([traceId])
}

model StoreSettings {
  id             String   @id @default(cuid())
  storeId        String   @unique
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String   @default("#111827")
  secondaryColor String   @default("#6b7280")
  accentColor    String   @default("#2563eb")
  currency       String   @default("ILS")
  languageDefault String  @default("he")
  rtlEnabled     Boolean  @default(true)
  whatsappPhone  String?
  storePhone        String?
  storeAddress      String?
  supportEmail      String?
  paymentProvider   String?
  paymentPublicKey  String?
  paymentSecretKey  String?
  paymentWebhookSecretOverride String?
  freeShippingMinAmount Decimal? @db.Decimal(12, 2)
  orderNumberPrefix String   @default("ORD")
  nextOrderNumber   Int      @default(1001)
  pickupEnabled     Boolean  @default(true)
  /// When false, /api/auth/register returns 403.
  registrationEnabled Boolean @default(true)
  /// When true, logged-in customers must verify email before checkout.
  requireEmailVerificationForCheckout Boolean @default(true)
  /// Terms of use (rich text / HTML allowed — rendered as HTML on storefront).
  terms_he       String?  @db.Text
  terms_ar       String?  @db.Text
  terms_en       String?  @db.Text
  privacy_he     String?  @db.Text
  privacy_ar     String?  @db.Text
  privacy_en     String?  @db.Text
  refund_he      String?  @db.Text
  refund_ar      String?  @db.Text
  refund_en      String?  @db.Text
  shipping_he    String?  @db.Text
  shipping_ar    String?  @db.Text
  shipping_en    String?  @db.Text
  /// Unpublished edits per tab/language until Publish ({ terms: { he: "..." }, ... }).
  policyDrafts   Json?
  termsPublishedAt    DateTime?
  privacyPublishedAt  DateTime?
  refundPublishedAt   DateTime?
  shippingPublishedAt DateTime?
  heroTitle_he      String?
  heroTitle_ar      String?
  heroTitle_en      String?
  heroSubtitle_he   String?
  heroSubtitle_ar   String?
  heroSubtitle_en   String?
  /// Product detail gallery image size preset for storefront + admin preview (small | medium | large | custom).
  productGalleryPreset       String  @default("medium")
  /// Used when preset is custom — max height in px (optional clamp).
  productGalleryMaxHeightPx  Int?
  /// Used when preset is custom — max width in px (optional clamp).
  productGalleryMaxWidthPx   Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id        String    @id @default(cuid())
  storeId   String?
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  email     String
  password  String
  role      UserRole
  emailVerified Boolean @default(false)
  emailVerifiedAt DateTime?
  acceptedTermsAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customerProfile CustomerProfile?
  emailVerificationTokens EmailVerificationToken[]

  @@unique([storeId, email])
  @@index([storeId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([userId])
  @@index([expiresAt])
}

model CustomerProfile {
  id            String    @id @default(cuid())
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone         String?
  birthDate     DateTime?
  pointsBalance Int       @default(0)
  totalOrders   Int       @default(0)
  totalSpent    Decimal   @default(0) @db.Decimal(12, 2)
  membershipBadge String? // e.g. VIP / GOLD / MEMBER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  loyaltyTransactions LoyaltyTransaction[]
  orders            Order[]
  memberships       CustomerMembership[]

  @@index([storeId])
}

model Category {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[] @relation("CategoryParent")
  name_he        String
  name_ar        String
  name_en        String
  description_he String?
  description_ar String?
  description_en String?
  imageUrl       String?
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]

  @@index([storeId])
  @@index([parentId])
}

model Product {
  id               String   @id @default(cuid())
  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title_he         String?
  title_ar         String?
  title_en         String?
  name_he          String
  name_ar          String
  name_en          String
  description_he   String?
  description_ar   String?
  description_en   String?
  price            Decimal  @db.Decimal(12, 2)
  oldPrice         Decimal? @db.Decimal(12, 2)
  discountPercent  Int?
  stock            Int      @default(0)
  sku              String
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  images    ProductImage[]
  variantGroups ProductVariantGroup[]
  relatedProducts ProductRelatedProduct[] @relation("MainProductRelations")
  relatedTo ProductRelatedProduct[] @relation("RelatedProducts")
  orderItems OrderItem[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([categoryId])
}

model ProductRelatedProduct {
  id               String   @id @default(cuid())
  productId        String
  relatedProductId String
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  product Product @relation("MainProductRelations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedProducts", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([relatedProductId])
  @@unique([productId, relatedProductId])
}

model ProductVariantGroup {
  id        String   @id @default(cuid())
  productId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductVariantOption[]

  @@index([productId])
}

model ProductVariantOption {
  id        String   @id @default(cuid())
  groupId   String
  value     String
  priceAdd  Decimal  @default(0) @db.Decimal(12, 2)
  stock     Int?
  sku       String?
  image     String?
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  group ProductVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model MembershipPlan {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         String   // one_time | monthly | yearly
  price        Decimal  @db.Decimal(12, 2)
  durationDays Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  memberships CustomerMembership[]

  @@index([storeId])
}

model CustomerMembership {
  id         String   @id @default(cuid())
  customerId String
  planId     String
  startDate  DateTime
  endDate    DateTime?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan     MembershipPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([planId])
  @@index([active])
}

model ProductImage {
  id        String   @id @default(cuid())
  storeId String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([productId])
}

model Banner {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title_he       String
  title_ar       String
  title_en       String
  subtitle_he    String?
  subtitle_ar    String?
  subtitle_en    String?
  imageUrl       String
  buttonText_he  String?
  buttonText_ar  String?
  buttonText_en  String?
  buttonUrl      String?
  type           BannerType @default(SECTION)
  isHero         Boolean  @default(false)
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
}

model DeliveryOption {
  id        String       @id @default(cuid())
  storeId   String
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name_he   String
  name_ar   String
  name_en   String
  type      DeliveryType
  price     Decimal      @db.Decimal(12, 2)
  active    Boolean      @default(true)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([storeId])
}

model Coupon {
  id             String     @id @default(cuid())
  storeId        String
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code           String
  type           CouponType
  value          Decimal    @db.Decimal(12, 2)
  minOrderAmount Decimal?   @db.Decimal(12, 2)
  usageLimit     Int?
  usedCount      Int        @default(0)
  active         Boolean    @default(true)
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([storeId, code])
  @@index([storeId])
}

model Order {
  id                   String             @id @default(cuid())
  storeId              String
  store                Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderNumber          String
  customerId           String?
  customerProfile      CustomerProfile?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName         String
  customerEmail        String
  customerPhone        String
  status               OrderStatus        @default(PENDING)
  paymentStatus        OrderPaymentStatus @default(UNPAID)
  fulfillmentStatus    OrderFulfillmentStatus @default(RECEIVED)
  subtotal             Decimal            @db.Decimal(12, 2)
  deliveryPrice        Decimal            @db.Decimal(12, 2)
  discountAmount       Decimal            @default(0) @db.Decimal(12, 2)
  pointsDiscountAmount Decimal            @default(0) @db.Decimal(12, 2)
  total                Decimal            @db.Decimal(12, 2)
  deliveryOptionName   String
  deliveryOptionType   DeliveryType
  deliveryOptionPrice  Decimal            @db.Decimal(12, 2)
  address              String?
  notes                String?
  couponCode           String?
  loyaltyPointsRedeemed Int               @default(0)
  inventoryReducedAt   DateTime?
  inventoryError       String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  items    OrderItem[]
  payments Payment[]
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([customerId])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([userId])
}

model PaymentWebhookLog {
  id             String                  @id @default(cuid())
  storeId        String
  store          Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider       String
  orderId        String?
  httpStatus     Int?
  status         PaymentWebhookLogStatus
  errorMessage   String?
  rawPayload     Json?
  createdAt      DateTime                @default(now())

  @@index([storeId])
  @@index([orderId])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// Cleared when product is bulk-deleted; line snapshot stays via productName / prices.
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String
  productImage String?
  variantOptionIds String[] @default([])
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  totalPrice   Decimal  @db.Decimal(12, 2)

  @@index([storeId])
  @@index([orderId])
}

model Payment {
  id                  String   @id @default(cuid())
  storeId             String
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider            String
  amount              Decimal  @db.Decimal(12, 2)
  currency            String
  status              String
  transactionId       String?
  confirmationNumber  String?
  rawPayload          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([storeId, transactionId])
  @@index([storeId])
  @@index([orderId])
}

model LoyaltySettings {
  id               String   @id @default(cuid())
  storeId          String   @unique
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(true)
  pointsPerShekel  Decimal  @default(1) @db.Decimal(12, 4)
  minOrderForPoints Decimal @default(0) @db.Decimal(12, 2)
  pointsToIlsRate  Decimal  @default(100) @db.Decimal(12, 4)
  allowRedeem      Boolean  @default(true)
  pointsExpireDays Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LoyaltyReward {
  id               String            @id @default(cuid())
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title_he         String
  title_ar         String
  title_en         String
  description_he   String?
  description_ar   String?
  description_en   String?
  requiredPoints   Int
  rewardType       LoyaltyRewardType
  value            String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([storeId])
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  storeId     String
  store       Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId  String
  customer    CustomerProfile        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type        LoyaltyTransactionType
  points      Int
  reason      String?
  createdAt   DateTime               @default(now())

  @@index([storeId])
  @@index([customerId])
}
